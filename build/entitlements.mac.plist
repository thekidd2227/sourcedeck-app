<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Hardened-runtime entitlements for SourceDeck.
  Required by Apple notarization. Keep this list MINIMAL — every
  entitlement here is a real capability the app uses; nothing is
  granted speculatively.

  - allow-jit / allow-unsigned-executable-memory: required by Electron's
    V8 JIT under the hardened runtime.
  - cs.disable-library-validation: required so Electron can load
    third-party Node addons inside the asar at runtime.
-->
<plist version="1.0">
<dict>
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
</dict>
</plist>
