# SourceDeck — example environment file. Placeholder names only.
# Copy to .env.local (gitignored) if you use env-based config in dev.
#
# PREFERRED: credentials are stored encrypted via the in-app secure
# keystore (safeStorage), set from the UI. The values below are only a
# development fallback and must never contain real secrets in source control.

# SAM.gov Get Opportunities API key (GovCon Opportunity Outreach Agent).
# Preferred path: Outreach tab -> Save Key (stored as credential 'sam-gov').
SAM_API_KEY=

# AI providers (optional dev fallback; preferred path is the in-app keystore).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Apollo enrichment (optional).
APOLLO_API_KEY=
