# Dependencies
node_modules/

# Electron-builder build output (artifacts go to release/ manually)
dist/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Logs
*.log
npm-debug.log*

# Local env
.env
.env.local

# QA-generated secrets (bearer-mode smoke). The script regenerates these
# on every run; never check them in.
qa/bearer-token.txt
qa/bearer-config.json

# Claude scratch
.claude/
CLAUDE_COMMAND.txt

# Marketing capture pack (generated by separate tooling — never ship in app repo)
marketing-capture/

# Unpacked app bundles (local build debris; the DMG / NSIS are the real artifacts)
release/mac/SourceDeck.app/
release/win/SourceDeck/
dist/_app_pack/

# Local DNS zone exports
sourcedeck-site-zone.txt

# Release artifacts (published via GitHub Releases, not versioned in source)
release/mac/*.dmg
release/mac/*.zip
release/mac/*.blockmap
release/mac/*.yml
release/win/*.exe
release/win/*.blockmap
release/win/*.yml
